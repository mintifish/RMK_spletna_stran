{
  "name": "rmk-site-tailwind",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/input.css -o ./rmk-theme/assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/css/input.css -o ./rmk-theme/assets/css/tailwind.css --watch",
    "build:css:prod": "cross-env NODE_ENV=production tailwindcss -i ./src/css/input.css -o ./rmk-theme/assets/css/tailwind.css --minify",
    "size-report": "node ./tools/size-report.js ./rmk-theme/assets/css/tailwind.css"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
